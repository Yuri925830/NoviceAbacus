# Web domain served by Aliyun ESA Pages.
APP_ENV=production
APP_BASE_URL=https://app.example.com

# Set this as an ESA Pages build variable. Use an API subdomain under the same root domain.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
CORS_ORIGINS=["https://app.example.com"]

# Run FastAPI on ECS/ACK and use RDS PostgreSQL or another persistent PostgreSQL service.
DATABASE_URL=postgresql+psycopg://xiaobai:replace-me@postgres.example.internal:5432/xiaobai
JWT_SIGNING_KEY=replace-with-a-new-random-value-of-at-least-32-characters
DATA_ENCRYPTION_KEY=replace-with-a-fernet-compatible-key
OWNER_ID=RENSHU
OWNER_EMAIL=
OWNER_PASSWORD=replace-with-a-strong-production-password
OWNER_PHONE=

# Alibaba Bailian credentials: inject as ECS secrets; do not commit the CSV or key.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
ALIYUN_WORKSPACE_ID=
QWEN_OCR_MODEL=qwen3.5-ocr
QWEN_VISION_MODEL=qwen3-vl-plus
QWEN_CHAT_MODEL=qwen3.7-plus
QWEN_COMPLEX_MODEL=qwen3.7-max

# Keep the gateway on a private ECS/container network; only FastAPI needs to reach it.
OPENAI_GATEWAY_URL=http://openai-gateway:8100
GATEWAY_SHARED_SECRET=replace-with-a-new-independent-random-secret
OPENAI_API_KEY=
OPENAI_ORDINARY_MODEL=gpt-5.6-terra
OPENAI_COMPLEX_MODEL=gpt-5.6-sol

FX_PROVIDER_URL=https://api.frankfurter.app
FX_MAX_AGE_HOURS=96

# 163 Mail uses implicit TLS on port 465.
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=rich_925@163.com
SMTP_PASSWORD=
SMTP_FROM=rich_925@163.com
ALERT_EMAIL=rich_925@163.com

MODEL_DAILY_REQUEST_LIMIT=120
MODEL_DAILY_COST_LIMIT=20
MAX_UPLOAD_MB=20
