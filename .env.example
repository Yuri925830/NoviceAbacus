APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Production: postgresql+psycopg://user:password@host:5432/xiaobai
DATABASE_URL=sqlite:///./data/xiaobai.db
JWT_SIGNING_KEY=replace-with-at-least-32-random-characters
DATA_ENCRYPTION_KEY=
OWNER_ID=owner
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=
OWNER_PHONE=

# Keep the Alibaba key in its original protected CSV if preferred.
ALIYUN_CREDENTIALS_CSV=C:/path/to/aliyun-api-key.csv
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
ALIYUN_WORKSPACE_ID=
QWEN_OCR_MODEL=qwen3.5-ocr
QWEN_VISION_MODEL=qwen3-vl-plus
QWEN_CHAT_MODEL=qwen3.7-plus
QWEN_COMPLEX_MODEL=qwen3.7-max

# OpenAI is called only by the separate gateway in supported regions.
OPENAI_GATEWAY_URL=http://localhost:8100
GATEWAY_SHARED_SECRET=replace-with-a-separate-random-secret
OPENAI_API_KEY=
OPENAI_ORDINARY_MODEL=gpt-5.6-terra
OPENAI_COMPLEX_MODEL=gpt-5.6-sol

FX_PROVIDER_URL=https://api.frankfurter.app
FX_MAX_AGE_HOURS=96

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL=

MODEL_DAILY_REQUEST_LIMIT=120
MODEL_DAILY_COST_LIMIT=20
MAX_UPLOAD_MB=20
